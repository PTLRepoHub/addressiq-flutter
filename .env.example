# AddressIQ Flutter SDK — local development overrides.
#
#   cp .env.example .env      # .env is gitignored; put real values there
#   flutter run --dart-define-from-file=.env
#
# EVERY value here is DEVELOPMENT-ONLY. The SDK honours them solely under
# `deployment: 'development'` and THROWS on a staging or production build, even
# if the variable is set. A build-time variable must never be able to point a
# shipped app at an arbitrary host.
#
# Leave a line blank/absent to keep the SDK's default for that value — each
# override is independent, so setting the API host does not drag the others along.

# ── Hosts ────────────────────────────────────────────────────────────────────
# Default is a hardcoded literal: 10.0.2.2:4000 on Android, localhost:4000
# elsewhere. 10.0.2.2 is an Android-EMULATOR alias for your machine — a PHYSICAL
# DEVICE cannot reach it, which is the main reason these exist. Use your LAN IP
# (`ipconfig getifaddr en0`) when running on real hardware.
ADDRESSIQ_API_URL=http://192.168.1.5:4000
ADDRESSIQ_INGEST_URL=http://192.168.1.5:4000
ADDRESSIQ_CDN_URL=http://192.168.1.5:5173

# ── Google Maps key ──────────────────────────────────────────────────────────
# Normally PLATFORM-PROVISIONED: the widget fetches a key from
# GET /api/v1/widget/config and falls back to the key baked into its bundle.
# Integrators never pass one, and this is deliberately not a field on
# AddressIQConfig. Set it only when your local backend has no key configured.
ADDRESSIQ_GOOGLE_MAPS_KEY=

# ── Widget bundle ────────────────────────────────────────────────────────────
# Points the WebView at a widget you serve yourself:
#   cd ../addressiq-web && npx rollup -c && npx serve dist -p 5173
# Gives live reload without re-vendoring. Point it at a published CDN URL
# (https://cdn.addressiqpro.com/v0.5.3/iqcollect.js) to exercise the remote-load
# + SRI + onerror-fallback paths, which `development` otherwise never takes.
# A file:// path will NOT work: the Android emulator is a separate VM and cannot
# see your filesystem. It must be served over HTTP.
ADDRESSIQ_WIDGET_URL=
